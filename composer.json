{
    "name": "kistn/laravel-client",
    "description": "Laravel plugin for the Kistn PHP client",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "kistn/php-client": "^0.0.1",
        "laravel/framework": "^13.0",
        "guzzlehttp/guzzle": "^7.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "orchestra/testbench": "^11.0",
        "mockery/mockery": "^1.6",
        "larastan/larastan": "^3.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Kistn\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kistn\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kistn\\Laravel\\ServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "@phpstan",
            "@rector:check",
            "@pest"
        ],
        "pest": "vendor/bin/pest --stop-on-failure",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=512M",
        "rector": "php -d memory_limit=512M vendor/bin/rector process",
        "rector:check": "php -d memory_limit=512M vendor/bin/rector process --dry-run"
    }
}
